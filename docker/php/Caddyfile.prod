{
	frankenphp
	# Render terminates TLS at its edge and forwards plain HTTP to the container,
	# so disable Caddy's own automatic HTTPS.
	auto_https off
}

# Bind the port Render assigns via $PORT (falls back to 8000 for local runs).
:{$PORT:8000} {
	root * /app/public
	encode zstd br gzip

	php_server
}
